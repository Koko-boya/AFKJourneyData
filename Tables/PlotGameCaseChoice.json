    {
      "ChoiceID": 1055,
      "Name": "石中剑仪式",
      "Text": "耀光帝国的继承人必须在见证下拔出石中剑，以获得统治帝国的资格。拔剑者需有奥古斯都家族的血脉。",
      "IsShow": {
        "$arrayRef": 1468
      },
      "RightChoiceID1": 1059,
      "Plotgame1": 17107101,
      "RightChoiceID2": 0,
      "Plotgame2": 0,
      "RightChoiceID3": 0,
      "Plotgame3": 0
    },
    {
      "ChoiceID": 1056,
      "Name": "圣古堂的消失",
      "Text": "圣古堂的失踪由法蒂玛一手操控，狮心猎场的袭击也与她有关。她很可能是奥利安的盟友之一。",
      "IsShow": {
        "$arrayRef": 1468
      },
      "RightChoiceID1": 1058,
      "Plotgame1": 17107102,
      "RightChoiceID2": 1057,
      "Plotgame2": 17107104,
      "RightChoiceID3": 0,
      "Plotgame3": 0
    },
    {
      "ChoiceID": 1057,
      "Name": "真假石中剑",
      "Text": "消失的圣古堂中所藏的石中剑实为伪造，可被法蒂玛操控。真正的石中剑则被秘密转移至狮心猎场的塔楼。",
      "IsShow": {
        "$arrayRef": 1468
      },
      "RightChoiceID1": 1059,
      "Plotgame1": 17107103,
      "RightChoiceID2": 1056,
      "Plotgame2": 17107104,
      "RightChoiceID3": 0,
      "Plotgame3": 0
    },
    {
      "ChoiceID": 1058,
      "Name": "佩吉的流言",
      "Text": "被困圣古堂的贵族们，亲眼见证了佩吉“无法拔剑”的一幕，进而传播她“不具备继承资格”的言论。",
      "IsShow": {
        "$arrayRef": 1468
      },
      "RightChoiceID1": 1056,
      "Plotgame1": 17107102,
      "RightChoiceID2": 0,
      "Plotgame2": 0,
      "RightChoiceID3": 0,
      "Plotgame3": 0
    },
    {
      "ChoiceID": 1059,
      "Name": "奥利安的身世",
      "Text": "奥利安并非国王马克西姆的亲生血脉，他与蛮血卡兹姆之间存在血缘联系。",
      "IsShow": {
        "$arrayRef": 1468
      },
      "RightChoiceID1": 1055,
      "Plotgame1": 17107101,
      "RightChoiceID2": 1057,
      "Plotgame2": 17107103,
      "RightChoiceID3": 0,
      "Plotgame3": 0
    },
    {
      "ChoiceID": 1006,
      "Name": "10623000274807237169",
      "Text": "答案所指之物能审判所有的错误。",
      "IsShow": {
        "$arrayRef": 1468
      },
      "RightChoiceID1": 1008,
      "Plotgame1": 16209400,
      "RightChoiceID2": 0,
      "Plotgame2": 0,
